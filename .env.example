# Spotify API (optional - only needed for metadata resolution)
# Get from developer.spotify.com
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Lidarr (existing instance)
# Get API key from Lidarr Settings > General
# If Lidarr runs on host machine: http://host.docker.internal:8686
# If Lidarr runs in Docker on same network: http://lidarr:8686
LIDARR_URL=http://lidarr:8686
LIDARR_API_KEY=your_lidarr_api_key_here

# Syncthing (existing instance)
# Get API key from Syncthing Settings > Actions > Show API Key
# If Syncthing runs on host machine: http://host.docker.internal:8384
# If Syncthing runs in Docker on same network: http://syncthing:8384
SYNCTHING_URL=http://syncthing:8384
SYNCTHING_API_KEY=your_syncthing_api_key_here
SYNCTHING_FOLDER_ID=music

# Auth (change before first run)
ADMIN_PASSWORD=changeme

# Redis
REDIS_URL=redis://redis:6379/0

# spotdl output format
SPOTDL_OUTPUT=/music/{artist}/{album}/{title}
SPOTDL_FORMAT=mp3
SPOTDL_BITRATE=320k

# App
SECRET_KEY=change_this_to_a_random_string

# Database (SQLite)
DATABASE_URL=sqlite:////data/spotsync.db